# Environment secrets — NEVER commit
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Node
node_modules/
frontend/dist/
frontend/build/

# Docker volumes (if mounted locally)
postgres_data/
redis_data/

# SSL certs (manage separately)
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Security reports — these stay but gitignore sensitive detail files
.reports/*.json
