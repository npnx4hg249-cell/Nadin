# =============================================================================
# Nadin Environment Configuration
# Copy this file to .env and fill in all required values
# NEVER commit .env to version control
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=nadin
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=nadin

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password_here

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32

# ─── Initial Admin Account ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change_me_strong_admin_password
ADMIN_USERNAME=admin

# ─── Token Expiry ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
TOTP_ISSUER=Nadin
# Comma-separated allowed origins for CORS (usually just your domain)
CORS_ORIGINS=http://localhost

# ─── LLM / Ollama ─────────────────────────────────────────────────────────────
# URL of the Ollama service (default matches docker-compose service name)
OLLAMA_URL=http://ollama:11434
# Model to use for NL→SQL and data translation
# See: https://ollama.com/library — any model works; code models are best for SQL
# Examples: qwen2.5-coder:7b-instruct (default), sqlcoder:7b, llama3.1:8b
OLLAMA_MODEL=qwen2.5-coder:7b-instruct
# Set to false to disable all LLM features (NL→SQL and data translation)
LLM_ENABLED=true

# ─── Cookie Security ─────────────────────────────────────────────────────────
# Set to true ONLY when the app is served over HTTPS.
# When false (default), the refresh-token cookie is sent over HTTP.
# If set to true on an HTTP-only deployment, browsers (especially Safari)
# will not send the cookie, causing users to be logged out every 30 minutes.
COOKIE_SECURE=false

# ─── Network Ports ────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
