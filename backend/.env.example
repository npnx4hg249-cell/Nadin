# ==========================================================================
# Nadin Backend — Environment Configuration
# Copy this file to .env and fill in all values before running the server.
# ==========================================================================

# --------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------
APP_NAME=Nadin
APP_ENV=development          # development | staging | production
DEBUG=false
SECRET_KEY=change-me-to-a-very-long-random-secret-key-at-least-32-chars
API_V1_PREFIX=/api/v1

# --------------------------------------------------------------------------
# PostgreSQL database
# --------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://nadin:nadin_pass@localhost:5432/nadin_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --------------------------------------------------------------------------
# Redis (session caching, rate limiting state)
# --------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=86400      # Session TTL in seconds (default 24 h)

# --------------------------------------------------------------------------
# JWT tokens
# --------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-another-very-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------------------------------------
# CORS — JSON list of allowed origins, or comma-separated string
# --------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true

# --------------------------------------------------------------------------
# Initial admin seed (applied at first startup)
# --------------------------------------------------------------------------
ADMIN_EMAIL=admin@nadin.local
ADMIN_PASSWORD=ChangeMe!1234
ADMIN_USERNAME=superadmin

# --------------------------------------------------------------------------
# Rate limiting (slowapi / Redis)
# --------------------------------------------------------------------------
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_DEFAULT=100/minute

# --------------------------------------------------------------------------
# TOTP / 2FA
# --------------------------------------------------------------------------
TOTP_ISSUER=Nadin

# --------------------------------------------------------------------------
# Uvicorn (used by entrypoint.sh)
# --------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
UVICORN_WORKERS=1
LOG_LEVEL=info

# --------------------------------------------------------------------------
# PostgreSQL wait-retry (used by entrypoint.sh)
# --------------------------------------------------------------------------
POSTGRES_CONNECT_RETRIES=30
